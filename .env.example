# Database
DB_URL=mysql://root:yourpassword@localhost:3306/railway

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_NUMBER=+1XXXXXXXXXX

# Admin Login (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=school@123

# Flask
SECRET_KEY=change_this_to_random_string
PORT=10000

# School Info
SCHOOL_NAME=Your School Name
SCHOOL_EMAIL=school@yourschool.com

# Gmail (for sending emails)
# Use App Password - NOT your regular Gmail password
# Go to: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=yourschool@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Twilio WhatsApp Sandbox Number
# Get from: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
